{
  "name": "antd",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript SDK for the Autonomi network via the antd daemon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "autonomi",
    "antd",
    "decentralized",
    "network",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "ethers": "^6.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
