{
    "name": "autonomi/antd",
    "description": "PHP SDK for the antd daemon — the gateway to the Autonomi decentralized network.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "web3p/ethereum-tx": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "Autonomi\\Antd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Autonomi\\Antd\\Tests\\": "tests/"
        }
    }
}
