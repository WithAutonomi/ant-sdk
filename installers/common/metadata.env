# Shared metadata for antd desktop installers.
#
# Single source of truth for asset filenames, install paths, and identifiers
# used across the Linux / macOS / Windows installer builders and the release CI.
# Shell builders `source` this file; the Windows build reads the same values via
# build-msi.ps1 (which parses this file). Keep in sync with the browser
# extension's src/shared/constants.ts (ANTD_INSTALLER_ASSETS, ANTD_RUN_GUIDE).

# --- Identity ------------------------------------------------------------
# Daemon binary name (antd / antd.exe on Windows).
ANTD_BINARY_NAME="antd"
# Reverse-DNS label shared by the macOS LaunchAgent and the Linux user unit.
ANTD_LABEL="com.autonomi.antd"
# Vendor / publisher shown in package metadata.
ANTD_VENDOR="Autonomi"
ANTD_MAINTAINER="Autonomi <support@autonomi.com>"
ANTD_HOMEPAGE="https://github.com/WithAutonomi/ant-sdk"
ANTD_DESCRIPTION="Autonomi antd daemon — REST + gRPC gateway for the Autonomi network"
ANTD_LICENSE="GPL-3.0"

# --- Runtime contract ----------------------------------------------------
# The daemon MUST be started with --cors (browser-origin REST) and listen on
# 127.0.0.1:8082 (default). Autostart is per-user / login-session only.
ANTD_RUN_FLAGS="--cors"
ANTD_REST_PORT="8082"

# --- Fixed release asset filenames (must match the extension's download URLs) -
ANTD_ASSET_MSI="antd-windows-x64-setup.msi"
ANTD_ASSET_PKG="antd-macos.pkg"
ANTD_ASSET_DEB="antd-linux-x64.deb"
ANTD_ASSET_RPM="antd-linux-x64.rpm"
ANTD_ASSET_INSTALL_SH="antd-linux-install.sh"

# --- Install paths (per OS) ---------------------------------------------
# Linux .deb/.rpm: matches the extension's "find & run" help text.
ANTD_LINUX_BIN="/usr/bin/antd"
# macOS .pkg.
ANTD_MACOS_BIN="/usr/local/bin/antd"
# Windows MSI: nested beside the GUI under the shared Autonomi\ parent.
ANTD_WINDOWS_DIR="C:\\Program Files\\Autonomi\\antd"

# --- Per-user data dirs (informational; antd derives these itself) -------
# Windows %APPDATA%\ant\sdk\  ·  macOS ~/Library/Application Support/ant/sdk/
# Linux ~/.local/share/ant/sdk/  ($XDG_DATA_HOME/ant/sdk/)
